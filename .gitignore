# --- Expo / React Native ---
.expo/
.expo-shared/
web-build/
expo-env.d.ts
.metro-health-check*

# Prebuild native dirs (Expo CNG). Remove if you commit android/ & ios/ in apps/*.
**/android/
**/ios/

# Native / RN build artifacts (when android/ & ios/ are tracked)
**/android/.gradle/
**/android/app/build/
**/android/build/
**/android/local.properties
**/ios/Pods/
**/ios/build/
**/ios/**/*.xcuserstate
**/ios/**/*.xcworkspace/xcuserdata/
**/ios/DerivedData/
*.hprof
*.orig.*

# --- Go ---
# Binaries & test artifacts
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Module cache & local tooling (keep go.sum and go.work committed)
/vendor/

# Common Go output dirs (per-app: apps/api/bin, etc.)
bin/
tmp/

# Coverage & profiling
coverage.out
coverage.html
*.prof
cpu.prof
mem.prof

# Delve debugger
__debug_bin*

# --- Podman / Compose (local overrides & runtime data) ---
# Local compose overrides (keep compose.yml / compose.yaml in repo)
compose.override.yml
compose.override.yaml
docker-compose.override.yml
docker-compose.override.yaml

# Local volume / bind-mount data (adjust paths if your infra layout differs)
infra/**/data/
infra/**/volumes/
*.volume

# Container logs dumped to disk
*.container.log

